generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String         @id @default(cuid())
  name           String
  email          String         @unique
  password       String
  currentStreak  Int            @default(0)
  longestStreak  Int            @default(0)
  lastActiveDate DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  refreshTokens  RefreshToken[]
  sleepLogs      SleepLog[]
  mealLogs       MealLog[]
  focusSessions  FocusSession[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model SleepLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  durationHrs  Float     // from slider, e.g. 7.5
  energyLevel  Int      // 1-5
  logDay       String   // "YYYY-MM-DD"
  createdAt    DateTime @default(now())
}

model MealLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealType  String   // breakfast, lunch, dinner, snack
  name      String   // what they ate
  calories  Int?     // optional
  logDay       String   // "YYYY-MM-DD"
  createdAt DateTime @default(now())
} 

model FocusSession {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label        String   // the focus note / goal
  durationMins Int      // planned timer duration
  completed    Boolean  @default(false)
  logDay       String   // "YYYY-MM-DD"
  createdAt    DateTime @default(now())
}